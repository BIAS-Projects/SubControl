<ContentPage
    x:Class="SubControlMAUI.Pages.FeatureOptionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:SubControlMAUI.Models"
    xmlns:vm="clr-namespace:SubControlMAUI.ViewModels"
    x:DataType="vm:FeatureOptionViewModel"
    Title="{Binding Title}"
        Shell.NavBarIsVisible="False">



    <Grid Padding="10"
          RowDefinitions="Auto, Auto,*,Auto"
          IsEnabled="{Binding IsNotBusy}">

        <!-- CUSTOM TITLE BAR -->
        <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto,*"
                  Margin="0,0,0,10">

            <Button Grid.Column="1"
                        Text="⬅ Back"
                        FontSize="18"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        Command="{Binding GoBackCommand}" />

            <Label Grid.Column="0"
                       Text="{Binding Title}"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Start"
                       VerticalOptions="Center" />

            <!-- Empty right column to keep title centred -->
            <Label Grid.Column="2" />

        </Grid>


        <Label Grid.Row="1"
                   Margin="0,15,0,15"
                   FontSize="16">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Status: " FontAttributes="Bold"/>
                    <Span Text="{Binding StatusText}" />
                </FormattedString>
            </Label.FormattedText>
        </Label>

        <ImageButton
            Grid.Row="1"
                    Source="{AppThemeBinding Light=light_download.png, Dark=dark_download.png}"
                    WidthRequest="30"
                    HeightRequest="30"
                    BackgroundColor="Transparent"
                Command="{Binding QueryDevicesCommand}"
                Margin="0,0,0,10" 
             IsEnabled="{Binding AppState.IsConnected}"/>

        <CollectionView Grid.Row="2"
                ItemsSource="{Binding UsbDevices}"
                IsEnabled="{Binding UsbDetailsDownloaded}"
                Margin="8,4,8,4">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:UsbDevice">
                    <Border Padding="5"
                    StrokeThickness="2"
                    Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*">
                            <!-- USB Device Name -->
                            <Label Text="{Binding Name}"
                           VerticalOptions="Center"
                           FontAttributes="Bold" />
                            <!-- Function Picker -->
                            <Picker Grid.Column="1"
                            Title="Select Function"
                            ItemsSource="{Binding AvailableFunctions}"
                            SelectedItem="{Binding SelectedFunction, Mode=TwoWay}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <ImageButton
                    Source="{AppThemeBinding Light=light_save.png, Dark=dark_save.png}"
                    WidthRequest="30"
                    HeightRequest="30"
                    BackgroundColor="Transparent"
            Grid.Row="3"
                Command="{Binding SaveCommand}"
            IsEnabled="{Binding UsbDetailsDownloaded}"
                Margin="0,10,0,0" />

        <!-- BUSY OVERLAY (on top) -->
        <Grid IsVisible="{Binding IsBusy}"
      BackgroundColor="#80000000"
      Grid.RowSpan="4"
      ZIndex="1">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                       IsVisible="{Binding IsBusy}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"
                       WidthRequest="60"
                       HeightRequest="60" />
        </Grid>

    </Grid>

</ContentPage>