<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:SubControlMAUI.ViewModels"
             x:Class="SubControlMAUI.Pages.FeatureOptionsPage"
             x:DataType="viewModel:FeatureOptionViewModel"
             Title="{Binding Title}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <Label Grid.Column="0"
               Grid.Row="0"
               Text="Enable Cutter Control"
               Margin="3"/>
        <CheckBox Grid.Column="1"
                  Grid.Row="0"
                  IsChecked="{Binding CutterEnabled}"
                  Margin="3"/>
        <Label Grid.Column="0"
               Grid.Row="1"
               Text="Enable Periscope Control"
               Margin="3"/>
        <CheckBox Grid.Column="1"
                  Grid.Row="1"
                  IsChecked="{Binding PeriscopeEnabled}"
                  Margin="3"/>

        <Button Grid.ColumnSpan="2"
                Grid.Row="2"
                Text="Save Settings"
                Command="{Binding SaveCommand}"
                Margin="3"/>

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Grid.ColumnSpan="2"
                           Grid.RowSpan="3"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           WidthRequest="50"
                           HeightRequest="50"/>

    </Grid>
</ContentPage>