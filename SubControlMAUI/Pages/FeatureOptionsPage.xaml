<ContentPage
    x:Class="SubControlMAUI.Pages.FeatureOptionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:SubControlMAUI.Models"
    xmlns:vm="clr-namespace:SubControlMAUI.ViewModels"
    x:DataType="vm:FeatureOptionViewModel"
    Title="{Binding Title}"
        Shell.NavBarIsVisible="True">

    <Grid Padding="10"
          RowDefinitions="Auto, Auto,*,Auto"
          IsEnabled="{Binding IsNotBusy}">
        
        <Label Grid.Row="0"
                   Margin="0,15,0,15"
                   FontSize="16">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Status: " FontAttributes="Bold"/>
                    <Span Text="{Binding StatusText}" />
                </FormattedString>
            </Label.FormattedText>
        </Label>

        <ImageButton
            Grid.Row="1"
                    Source="{AppThemeBinding Light=light_download.png, Dark=dark_download.png}"
                    WidthRequest="30"
                    HeightRequest="30"
                    BackgroundColor="Transparent"
                Command="{Binding QueryDevicesCommand}"
                Margin="0,0,0,10" 
             IsEnabled="{Binding AppState.IsConnected}"/>


        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding UsbDevices}"
                        IsEnabled="{Binding UsbDetailsDownloaded}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:UsbDevice">

                    <Grid ColumnDefinitions="*,*"
                          Padding="5">

                        <!-- USB Device Name -->
                        <Label Text="{Binding Name}"
                               VerticalOptions="Center"
                               FontAttributes="Bold" />

                        <!-- Function Picker -->
                        <Picker Grid.Column="1"
        Title="Select Function"
        ItemsSource="{Binding AvailableFunctions}"
        SelectedItem="{Binding SelectedFunction, Mode=TwoWay}" />

                    </Grid>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ImageButton
                    Source="{AppThemeBinding Light=light_save.png, Dark=dark_save.png}"
                    WidthRequest="30"
                    HeightRequest="30"
                    BackgroundColor="Transparent"
            Grid.Row="3"
                Command="{Binding SaveCommand}"
            IsEnabled="{Binding UsbDetailsDownloaded}"
                Margin="0,10,0,0" />

        <!-- BUSY OVERLAY (on top) -->
        <Grid IsVisible="{Binding IsBusy}"
      BackgroundColor="#80000000"
      Grid.RowSpan="4"
      ZIndex="1">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                       IsVisible="{Binding IsBusy}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"
                       WidthRequest="60"
                       HeightRequest="60" />
        </Grid>

    </Grid>

</ContentPage>