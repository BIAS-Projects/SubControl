<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SubControlMAUI.Pages.TechPage"
             xmlns:vm="clr-namespace:SubControlMAUI.ViewModels"
             x:DataType="vm:TechViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False">
    <VerticalStackLayout>
        <!-- CUSTOM TITLE BAR -->
        <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto,*"
                  Margin="0,0,0,10">

            <Button Grid.Column="1"
                        Text="⬅ Back"
                        FontSize="18"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        Command="{Binding GoBackCommand}" />

            <Label Grid.Column="0"
                       Text="{Binding Title}"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Start"
                       VerticalOptions="Center" />

            <!-- Empty right column to keep title centred -->
            <Label Grid.Column="2" />

        </Grid>
    </VerticalStackLayout>
</ContentPage>