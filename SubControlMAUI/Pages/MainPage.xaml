<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:SubControlMAUI.ViewModels"
             xmlns:controls="clr-namespace:SubControlMAUI.Controls"
             x:Class="SubControlMAUI.Pages.MainPage"
             x:DataType="viewModel:MainViewModel"
             Title="{Binding Title}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6*"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>


        
        <Label 
            Text="{Binding Status}"
            Grid.Row="0"
            Grid.ColumnSpan="2"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            FontSize="Medium"
            Margin="10"/>


        <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" HorizontalOptions="Center" Spacing="10" Padding="10">
            <Button 
           IsEnabled="{Binding IsNotConnected}"
           Text="Connect"
           Command="{Binding ConnectCommand}"/>

            <Button 
           IsEnabled="{Binding IsConnected}"
           Text="Disconnect"
           Command="{Binding DisconnectCommand}"/>

            <Button 
           IsEnabled="{Binding IsConnected}"
           Text="StartTOM"
           Command="{Binding StartTOMCommand}"/>

            <Button 
           IsEnabled="{Binding IsConnected}"
           Text="StopTOM"
           Command="{Binding StopTOMCommand}"/>

            <Button 
           IsEnabled="{Binding IsConnected}"
           Text="List USB Ports"
           Command="{Binding GetAllUSBPortsCommand}"/>

            <Button 
           IsEnabled="{Binding IsConnected}"
           Text="List Video Ports"
           Command="{Binding GetVideoPortsCommand}"/>
        </HorizontalStackLayout>



 

        <controls:VideoView  
            Stream="{Binding ActiveStream}"
            BackgroundColor="Black"
            VerticalOptions="Fill"
            HorizontalOptions="Fill"
            Grid.ColumnSpan="2"
            Grid.Row="2"/>




        <HorizontalStackLayout Grid.Row="3" Grid.ColumnSpan="2" HorizontalOptions="Center" Spacing="10" Padding="10">
            <Button Text="Port 5001" Command="{Binding SwitchStreamCommand}" 
                    CommandParameter="{Binding AvailableStreams[0]}" />
            <Button Text="Port 5002" Command="{Binding SwitchStreamCommand}" 
                    CommandParameter="{Binding AvailableStreams[1]}" />
            <Button Text="Port 5003" Command="{Binding SwitchStreamCommand}" 
                    CommandParameter="{Binding AvailableStreams[2]}" />
            <Button Text="Start All" Command="{Binding StartAllStreamsCommand}" BackgroundColor="Green" />
        </HorizontalStackLayout>



        <!--<Button 
            IsEnabled="{Binding IsConnected}"
            Text="GetUSBPorts"
            Command="{Binding GetUSBPortsCommand}"
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Margin="10"
            Loaded="Button_Loaded"/>-->
        <!--<Button 
            IsEnabled="{Binding IsConnected}"
            Text="Down"
            Command="{Binding DownCommand}"
            Grid.Row="4"
            Grid.ColumnSpan="2"
            Margin="10"/>

        <Button 
            IsEnabled="{Binding CanStart}"
            Text="Cutter On"
            Command="{Binding CutterOnCommand}"
            Grid.Row="5"
            Grid.Column="0"
            Margin="10"/>
        <Button 
            IsEnabled="{Binding CanStop}"
            Text="Cutter Off"
            Command="{Binding CutterOffCommand}"
            Grid.Row="5"
            Grid.Column="1"
            Margin="10"/>
        <Slider 

            Minimum="0"
            Maximum="100"
            Value="{Binding SliderValue, Mode=TwoWay}"
            Grid.Row="6"
            Grid.ColumnSpan="2"
            Margin="10"/>

        <Label 
            Text="{Binding CutterCurrent}"
            Grid.Row="7"
            Grid.ColumnSpan="2"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            FontSize="Medium"
            Margin="10"/>-->

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Grid.ColumnSpan="2"
                           Grid.RowSpan="5"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           WidthRequest="50"
                           HeightRequest="50"/>
    </Grid>
</ContentPage>