<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:SubControlMAUI.ViewModels"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="SubControlMAUI.Pages.MainPage"
             x:DataType="viewModel:MainViewModel"
             Title="{Binding Title}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6*"/>

        </Grid.RowDefinitions>


        
        <Label 
            Text="{Binding Status}"
            Grid.Row="0"
            Grid.ColumnSpan="2"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            FontSize="Medium"
            Margin="10"/>

        
        

        <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" HorizontalOptions="Center" Spacing="10" Padding="10">
            <Button 
           IsEnabled="{Binding IsNotConnected}"
           Text="Connect"
           Command="{Binding ConnectCommand}"/>

            <Button 
           IsEnabled="{Binding IsConnected}"
           Text="Disconnect"
           Command="{Binding DisconnectCommand}"/>

            <Button 
           IsEnabled="{Binding IsConnected}"
           Text="StartTOM"
           Command="{Binding StartTOMCommand}"/>

            <Button 
           IsEnabled="{Binding IsConnected}"
           Text="StopTOM"
           Command="{Binding StopTOMCommand}"/>

            <Button 
           IsEnabled="{Binding IsConnected}"
           Text="List USB Ports"
           Command="{Binding ListDevicesCommand}"/>

            <Button 
           IsEnabled="{Binding IsConnected}"
           Text="List Video Ports"
           Command="{Binding GetVideoPortsCommand}"/>
            
            <Label 

            Text="{Binding StatusLabel}"
            Grid.Row="0"
            Grid.ColumnSpan="2"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            FontSize="Micro"
            Margin="10"/>

        </HorizontalStackLayout>


        <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" HorizontalOptions="Center">
            <!-- URL row -->
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                <Entry x:Name="UrlEntry"
                   Grid.Column="0"
                   Text="rtsp://localhost:8554/usbcamera"
                   Placeholder="rtsp://..."
                   PlaceholderColor="#666"
                   TextColor="White"
                   BackgroundColor="#2d2d2d"
                   ReturnType="Done"
                   Completed="OnUrlCompleted"/>

                <Button x:Name="ConnectBtn"
                    Grid.Column="1"
                    Text="Connect"
                    BackgroundColor="#0078d4"
                    TextColor="White"
                    CornerRadius="6"
                    Padding="16,0"
                    Clicked="OnConnectClicked"/>
            </Grid>

            <!-- Status + controls row -->
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">

                <Label x:Name="StatusLabel"
                   Grid.Column="0"
                   Text="Disconnected"
                   TextColor="#888"
                   VerticalOptions="Center"
                   FontSize="13"/>

                <HorizontalStackLayout Grid.Column="1" Spacing="8">

                    <Label x:Name="FpsLabel"
                       Text="-- fps"
                       TextColor="#888"
                       VerticalOptions="Center"
                       FontSize="13"
                       WidthRequest="60"/>

                    <Button x:Name="StopBtn"
                        Text="⏹"
                        FontSize="18"
                        BackgroundColor="#333"
                        TextColor="White"
                        CornerRadius="6"
                        WidthRequest="48"
                        HeightRequest="40"
                        Padding="0"
                        IsEnabled="False"
                        Clicked="OnStopClicked"/>

                    <Button x:Name="SnapBtn"
                        Text="📷"
                        FontSize="18"
                        BackgroundColor="#333"
                        TextColor="White"
                        CornerRadius="6"
                        WidthRequest="48"
                        HeightRequest="40"
                        Padding="0"
                        IsEnabled="False"
                        Clicked="OnSnapClicked"/>

                    <Button x:Name="FLIR_WHITEHOT"
                        Text="WHITEHOT"
                        FontSize="18"
                        BackgroundColor="#333"
                        TextColor="White"
                        CornerRadius="6"
                        WidthRequest="90"
                        HeightRequest="40"
                        Padding="0"
                        IsEnabled="True"
                        Command="{Binding FLIRWhitehotCommand}"/>

                    <Button x:Name="FLIR_RAINBOW"
                        Text="RAINBOW"
                        FontSize="18"
                        BackgroundColor="#333"
                        TextColor="White"
                        CornerRadius="6"
                        WidthRequest="90"
                        HeightRequest="40"
                        Padding="0"
                        IsEnabled="True"
                        Command="{Binding FLIRRainbowCommand}"/>


                    <Button x:Name="RotorForward"
                        Text="◀"
                        FontSize="18"
                        BackgroundColor="#333"
                        TextColor="White"
                        CornerRadius="6"
                        WidthRequest="90"
                        HeightRequest="40"
                        Padding="0"
                        IsEnabled="True"
                        Command="{Binding RotorForwardCommand}"/>

                    <Button x:Name="RotorBack"
                        Text="▶"
                        FontSize="18"
                        BackgroundColor="#333"
                        TextColor="White"
                        CornerRadius="6"
                        WidthRequest="90"
                        HeightRequest="40"
                        Padding="0"
                        IsEnabled="True"
                        Command="{Binding RotorBackwardCommand}"/>

                    <Button x:Name="RotorStop"
                        Text="◼"
                        FontSize="18"
                        BackgroundColor="#333"
                        TextColor="White"
                        CornerRadius="6"
                        WidthRequest="90"
                        HeightRequest="40"
                        Padding="0"
                        IsEnabled="True"
                        Command="{Binding RotorStopCommand}"/>


                </HorizontalStackLayout>
            </Grid>

        </HorizontalStackLayout>


        <!-- SkiaSharp canvas — redraws on every decoded frame -->
        <skia:SKCanvasView x:Name="CanvasView"
                           Grid.Row="3"
                           Grid.ColumnSpan="2"
                           PaintSurface="OnPaintSurface"
                           BackgroundColor="Black"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill"/>










        <ActivityIndicator x:Name="Spinner"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Grid.ColumnSpan="2"
                           Grid.RowSpan="5"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           WidthRequest="50"
                           HeightRequest="50"/>
    </Grid>
</ContentPage>