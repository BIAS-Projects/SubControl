<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SubControlMAUI.Pages.VideoConfigPage"
             xmlns:vm="clr-namespace:SubControlMAUI.ViewModels"
             xmlns:models="clr-namespace:SubControlMAUI.Models"
             x:DataType="vm:VideoConfigViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False">
    <Grid Padding="10"
          RowDefinitions="Auto,Auto,Auto,*,Auto"
          IsEnabled="{Binding IsNotBusy}">

        <!-- CUSTOM TITLE BAR -->
        <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto,*"
                  Margin="0,0,0,10">

            <Button Grid.Column="1"
                        Text="⬅ Back"
                        FontSize="18"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        Command="{Binding GoBackCommand}" />

            <Label Grid.Column="0"
                       Text="{Binding Title}"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Start"
                       VerticalOptions="Center" />

            <!-- Empty right column to keep title centred -->
            <Label Grid.Column="2" />

        </Grid>


        <!-- Status -->
        <Label Grid.Row="1"
               Margin="0,15,0,15"
               FontSize="16">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Status: " FontAttributes="Bold"/>
                    <Span Text="{Binding StatusText}" />
                </FormattedString>
            </Label.FormattedText>
        </Label>

        <!-- Download button -->
        <ImageButton Grid.Row="2"
                     Source="{AppThemeBinding Light=light_download.png, Dark=dark_download.png}"
                     WidthRequest="30"
                     HeightRequest="30"
                     BackgroundColor="Transparent"
                     Command="{Binding QueryDevicesCommand}"
                     Margin="0,0,0,10" 
                      IsEnabled="{Binding AppState.IsConnected}"/>

        <!-- Camera list -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Cameras}"
                        IsEnabled="{Binding CameraDetailsDownloaded}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:CameraDevice">
                    <Border Padding="5"
    StrokeThickness="2"
    Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray950}}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="*,*" Padding="5">
                        <Label Text="{Binding DeviceId}"
               VerticalOptions="Center"
               FontAttributes="Bold"
               LineBreakMode="TailTruncation" />
                        <Picker Grid.Column="1"
                Title="Select Stream"
                ItemsSource="{Binding AvailableProfiles}"
                SelectedItem="{Binding SelectedProfile, Mode=TwoWay}" />
                    </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Save button -->
        <ImageButton Grid.Row="4"
                     Source="{AppThemeBinding Light=light_save.png, Dark=dark_save.png}"
                     WidthRequest="30"
                     HeightRequest="30"
                     BackgroundColor="Transparent"
                     Command="{Binding SaveCommand}"
                     IsEnabled="{Binding CameraDetailsDownloaded}"
                     Margin="0,10,0,0"/>

        <!-- Busy overlay -->
        <Grid IsVisible="{Binding IsBusy}"
      BackgroundColor="#80000000"
      Grid.RowSpan="5"
      ZIndex="1">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                       IsVisible="{Binding IsBusy}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"
                       WidthRequest="60"
                       HeightRequest="60" />
        </Grid>

    </Grid>
</ContentPage>