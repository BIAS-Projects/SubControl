<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:SubControlMAUI.ViewModels"
             x:Class="SubControlMAUI.Pages.PeriscopeCommandSettingsPage"
             x:DataType="viewModel:PeriscopeCommandViewModel"
             Title="{Binding Title}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />

        </Grid.RowDefinitions>


        <Label Text="Up Command:"
               Grid.Column="0"
               Grid.Row="0"
               HorizontalOptions="Start"
               VerticalOptions="Center"
               Margin="3"/>
        <Entry x:Name="upCommand"
               IsEnabled="{Binding IsNotConnected}"
                Grid.Column="1"
                Grid.Row="0"
                HeightRequest="40"
                Placeholder="Up Command"
               Text="{Binding UpCommand}"
               Margin="3"/>

        <Label Text="Down Command:"
               Grid.Column="0"
               Grid.Row="1"
               HorizontalOptions="Start"
               VerticalOptions="Center"
               Margin="3"/>
        <Entry x:Name="downCommand"
               IsEnabled="{Binding IsNotConnected}"
                Grid.Column="1"
                Grid.Row="1"
                HeightRequest="40"
                Placeholder="Down Command"
               Text="{Binding DownCommand}"
               Margin="3"/>

        <Button 
            IsEnabled="{Binding IsNotConnected}"
            Text="Save"
            Command="{Binding SaveCommand}"
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Margin="3"/>

        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Grid.ColumnSpan="2"
                           Grid.RowSpan="3"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           WidthRequest="50"
                           HeightRequest="50"/>

    </Grid>
    
</ContentPage>