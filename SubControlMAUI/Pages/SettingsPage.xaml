<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:SubControlMAUI.ViewModels"
             x:Class="SubControlMAUI.Pages.SettingsPage"
             x:DataType="viewModel:SettingsViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="False">
    <Grid Padding="10"
          RowDefinitions="Auto, Auto,Auto,Auto,*,Auto"
          ColumnDefinitions="*,*">

        <!-- CUSTOM TITLE BAR -->
        <Grid Grid.Row="0"
              Grid.ColumnSpan="2"
                  ColumnDefinitions="*,Auto,*"
                  Margin="0,0,0,10">

            <Button Grid.Column="1"
                        Text="⬅ Back"
                        FontSize="18"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        Command="{Binding GoBackCommand}" />

            <Label Grid.Column="0"
                       Text="{Binding Title}"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalOptions="Start"
                       VerticalOptions="Center" />

            <!-- Empty right column to keep title centred -->
            <Label Grid.Column="2" />

        </Grid>



        <Label Grid.Row="1"
                   Margin="0,15,0,15"
                   FontSize="16">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Status: " FontAttributes="Bold"/>
                    <Span Text="{Binding StatusText}" />
                </FormattedString>
            </Label.FormattedText>
        </Label>

        <Label Text="IP Address:"
               Grid.Column="0"
               Grid.Row="2"
               HorizontalOptions="Start"
               VerticalOptions="Center"
               Margin="3"/>
        <Entry x:Name="ipAddress"
               IsEnabled="{Binding IsNotConnected}"
                Grid.Column="1"
                Grid.Row="2"
                HeightRequest="40"
                Placeholder="IP Address"
               Text="{Binding InputIPAddress}"
               Margin="3"/>

        <Label Text="Port:"
               Grid.Column="0"
               Grid.Row="3"
               HorizontalOptions="Start"
               VerticalOptions="Center"
               Margin="3"/>
        <Entry x:Name="port"
                IsEnabled="{Binding IsNotConnected}"
                Grid.Column="1"
                Grid.Row="3"
                HeightRequest="40"
                Placeholder="Port"
               Text="{Binding Port}"
                Margin="3"/>



        <ImageButton
                    Source="{AppThemeBinding Light=light_save.png, Dark=dark_save.png}"
                    WidthRequest="30"
                    HeightRequest="30"
                    BackgroundColor="Transparent"
            Grid.Row="5"
            Grid.ColumnSpan="2"
                Command="{Binding SaveCommand}"
            IsEnabled="{Binding IsNotBusy}"
                Margin="0,10,0,0" />





        <!-- BUSY OVERLAY (on top) -->
        <!-- Busy overlay -->
        <Grid IsVisible="{Binding IsBusy}"
      BackgroundColor="#80000000"
      Grid.RowSpan="6"
      ZIndex="1">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                       IsVisible="{Binding IsBusy}"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"
                       WidthRequest="60"
                       HeightRequest="60" />
        </Grid>

    </Grid>
</ContentPage>