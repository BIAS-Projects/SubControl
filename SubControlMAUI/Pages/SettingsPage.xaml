<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:SubControlMAUI.ViewModels"
             x:Class="SubControlMAUI.Pages.SettingsPage"
             x:DataType="viewModel:SettingsViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="True">
    <Grid Padding="10"
          RowDefinitions="Auto, Auto,Auto,*,Auto"
          ColumnDefinitions="*,*">

        <Label Grid.Row="0"
                   Margin="0,15,0,15"
                   FontSize="16">
            <Label.FormattedText>
                <FormattedString>
                    <Span Text="Status: " FontAttributes="Bold"/>
                    <Span Text="{Binding StatusText}" />
                </FormattedString>
            </Label.FormattedText>
        </Label>

        <Label Text="IP Address:"
               Grid.Column="0"
               Grid.Row="1"
               HorizontalOptions="Start"
               VerticalOptions="Center"
               Margin="3"/>
        <Entry x:Name="ipAddress"
               IsEnabled="{Binding IsNotConnected}"
                Grid.Column="1"
                Grid.Row="1"
                HeightRequest="40"
                Placeholder="IP Address"
               Text="{Binding InputIPAddress}"
               Margin="3"/>

        <Label Text="Port:"
               Grid.Column="0"
               Grid.Row="2"
               HorizontalOptions="Start"
               VerticalOptions="Center"
               Margin="3"/>
        <Entry x:Name="port"
                IsEnabled="{Binding IsNotConnected}"
                Grid.Column="1"
                Grid.Row="2"
                HeightRequest="40"
                Placeholder="Port"
               Text="{Binding Port}"
                Margin="3"/>



        <ImageButton
                    Source="{AppThemeBinding Light=light_save.png, Dark=dark_save.png}"
                    WidthRequest="30"
                    HeightRequest="30"
                    BackgroundColor="Transparent"
            Grid.Row="4"
            Grid.ColumnSpan="2"
                Command="{Binding SaveCommand}"
            IsEnabled="{Binding IsNotBusy}"
                Margin="0,10,0,0" />





        <!-- BUSY OVERLAY (on top) -->
        <Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="#80000000"
              ZIndex="1">

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               WidthRequest="60"
                               HeightRequest="60" />
        </Grid>

    </Grid>
</ContentPage>