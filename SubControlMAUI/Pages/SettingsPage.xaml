<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModel="clr-namespace:SubControlMAUI.ViewModels"
             x:Class="SubControlMAUI.Pages.SettingsPage"
             x:DataType="viewModel:SettingsViewModel"
             Title="{Binding Title}"
             Shell.NavBarIsVisible="True">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <Label Text="IP Address:"
               Grid.Column="0"
               Grid.Row="0"
               HorizontalOptions="Start"
               VerticalOptions="Center"
               Margin="3"/>
        <Entry x:Name="ipAddress"
               IsEnabled="{Binding IsNotConnected}"
                Grid.Column="1"
                Grid.Row="0"
                HeightRequest="40"
                Placeholder="IP Address"
               Text="{Binding InputIPAddress}"
               Margin="3"/>

        <Label Text="Port:"
               Grid.Column="0"
               Grid.Row="1"
               HorizontalOptions="Start"
               VerticalOptions="Center"
               Margin="3"/>
        <Entry x:Name="port"
                IsEnabled="{Binding IsNotConnected}"
                Grid.Column="1"
                Grid.Row="1"
                HeightRequest="40"
                Placeholder="Port"
               Text="{Binding Port}"
                Margin="3"/>



        <Button 
            IsEnabled="{Binding IsNotConnected}"
            Text="Save"
            Command="{Binding SaveCommand}"
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Margin="3"/>



        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Grid.ColumnSpan="2"
                           Grid.Row="6"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           WidthRequest="50"
                           HeightRequest="50"/>

    </Grid>
</ContentPage>