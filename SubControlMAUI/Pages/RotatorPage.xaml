<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="SubControlMAUI.Pages.RotatorPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SubControlMAUI.ViewModels"
    x:DataType="vm:RotatorViewModel"
    Title="{Binding Title}"
    Shell.NavBarIsVisible="True">

    <Grid>

        <!-- ===================================================== -->
        <!-- MAIN CONTENT -->
        <!-- ===================================================== -->

        <Grid RowDefinitions="Auto,Auto,*,Auto"
              Padding="20">
            <!-- ========================================================= -->
            <!-- STATUS BAR -->
            <!-- ========================================================= -->

            <Border Grid.Row="0"
                StrokeThickness="0"
                Padding="12,8">

                <Grid ColumnDefinitions="Auto,*">

                    <Label Text="Status:"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />

                    <Label Grid.Column="1"
                       Margin="10,0,0,0"
                       Text="{Binding StatusText}"
                       VerticalOptions="Center"
                       LineBreakMode="TailTruncation" />

                </Grid>

            </Border>

            <!-- SLIDER -->

            <Slider Grid.Row="1"
                    Margin="0,30,0,30"
                    Minimum="0"
                    Maximum="180"
                    Value="{Binding ArmAngle, Mode=TwoWay}"
                    IsEnabled="False"/>

            <!-- CENTER VISUAL -->

            <Grid Grid.Row="2">

                <Border StrokeThickness="2"
                        Stroke="{AppThemeBinding Light=Black, Dark=White}"
                        StrokeShape="RoundRectangle 20"
                        Padding="40"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">

                    <VerticalStackLayout Spacing="20">

                        <Label Text="Rotator Position"
                               FontSize="20"
                               HorizontalOptions="Center"/>

                        <Label Text="{Binding ArmAngle, StringFormat='{0:F0}°'}"
                               FontSize="48"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>

                    </VerticalStackLayout>

                </Border>

            </Grid>

            <!-- BUTTONS -->

            <Grid Grid.Row="3"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="20"
                  Margin="0,30,0,0">

                <!-- LEFT -->

                <Button Grid.Column="0"
                        Text="◀"
                        FontSize="36"
                        HeightRequest="80"
                        Command="{Binding ParkCommand}"
                        IsEnabled="{Binding IsNotBusy}"/>

                <!-- STOP -->

                <Button Grid.Column="1"
                        Text="STOP"
                        FontSize="24"
                        HeightRequest="80"
                   
          
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsNotBusy}"
                        />

                <!-- RIGHT -->

                <Button Grid.Column="2"
                        Text="▶"
                        FontSize="36"
                        HeightRequest="80"
                        Command="{Binding DeployCommand}"
                        IsEnabled="{Binding IsNotBusy}"/>

            </Grid>

        </Grid>

         <!--===================================================== 
         BUSY OVERLAY 
         =====================================================--> 

        <!--<Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="#80000000"
              ZIndex="10">

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                WidthRequest="60"
                HeightRequest="60"/>

        </Grid>-->

    </Grid>

</ContentPage>