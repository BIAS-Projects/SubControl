<ContentPage
    x:Class="SubControlMAUI.Pages.USBConfigMenuPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SubControlMAUI.ViewModels"
    x:DataType="vm:USBConfigMenuViewModel"
    Title="{Binding Title}"
        Shell.NavBarIsVisible="False">

    <Grid>

        <Grid RowDefinitions="*,8*" Padding="10">


            <!-- CUSTOM TITLE BAR -->
            <Grid Grid.Row="0"
      ColumnDefinitions="*,Auto,*"
      Margin="0,0,0,10">

                <Button Grid.Column="1"
            Text="⬅ Back"
            FontSize="18"
            HorizontalOptions="Start"
            VerticalOptions="Center"
            Command="{Binding GoBackCommand}" />

                <Label Grid.Column="0"
           Text="{Binding Title}"
           FontSize="22"
           FontAttributes="Bold"
           HorizontalOptions="Start"
           VerticalOptions="Center" />

                <!-- Empty right column to balance the back button -->
                <BoxView Grid.Column="2" Color="Transparent" />

            </Grid>

            <!-- Main Buttons -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="*,*,*,*,*"
                  ColumnSpacing="60"
                  HorizontalOptions="Center"
                  VerticalOptions="Center">




                <!-- ETHERNET -->
                <!--<VerticalStackLayout Grid.Column="0"
                                     Spacing="8"
                                     HorizontalOptions="Center">

                    <ImageButton
                        Source="{AppThemeBinding Light=light_ethernet.png, Dark=dark_ethernet.png}"
                        WidthRequest="{Binding ButtonSize}"
                        HeightRequest="{Binding ButtonSize}"
                        BackgroundColor="Transparent"
                        Command="{Binding EthernetCommand}"
                        />


                    <Label Text="Ethernet"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>-->

                <!-- FEATURES -->
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="8"
                                     HorizontalOptions="Center">

                    <ImageButton
                        Source="{AppThemeBinding Light=light_checkbox.png, Dark=dark_checkbox.png}"
                        WidthRequest="{Binding ButtonSize}"
                        HeightRequest="{Binding ButtonSize}"
                        BackgroundColor="Transparent"
                        Command="{Binding FeaturesCommand}"
                        IsEnabled="{Binding _AppState.IsConnected}" />


                    <Label Text="USB Features"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2"
                                     Spacing="8"
                                     HorizontalOptions="Center">

                    <ImageButton
                        Source="{AppThemeBinding Light=light_video.png, Dark=dark_video.png}"
                        WidthRequest="{Binding ButtonSize}"
                        HeightRequest="{Binding ButtonSize}"
                        BackgroundColor="Transparent"
                        Command="{Binding VideoCommand}"
                        IsEnabled="{Binding _AppState.IsConnected}" />


                    <Label Text="USB Video"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!--<VerticalStackLayout Grid.Column="3"
                                     Spacing="8"
                                     HorizontalOptions="Center">

                    <ImageButton
                        Source="{AppThemeBinding Light=light_roundabout.png, Dark=dark_roundabout.png}"
                        WidthRequest="{Binding ButtonSize}"
                        HeightRequest="{Binding ButtonSize}"
                        BackgroundColor="Transparent"
                        Command="{Binding RotatorCommand}"
                         />


                    <Label Text="Rotator"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>-->


                <!--<VerticalStackLayout Grid.Column="4"
                                     Spacing="8"
                                     HorizontalOptions="Center">

                    <ImageButton
                        Source="{AppThemeBinding Light=light_tech.png, Dark=dark_tech.png}"
                        WidthRequest="{Binding ButtonSize}"
                        HeightRequest="{Binding ButtonSize}"
                        BackgroundColor="Transparent"
                        Command="{Binding TechCommand}"
                         />


                    <Label Text="Technical"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>-->

            </Grid>
        </Grid>

        <!-- BUSY OVERLAY -->
        <Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="#80000000"
              ZIndex="1">

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               WidthRequest="60"
                               HeightRequest="60" />
        </Grid>

    </Grid>

</ContentPage>