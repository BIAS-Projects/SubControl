<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SubControlMAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SubControlMAUI"
    xmlns:pages="clr-namespace:SubControlMAUI.Pages"
    Title="SubControlMAUI">

    <TabBar>
        <Tab Title="Main" Icon="submarine.png">
            <ShellContent
            ContentTemplate="{DataTemplate pages:MainPage}"
            Route="MainPage" />
        </Tab>
        <Tab Title="Settings" Icon="settings.png">
            <ShellContent
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="SettingsPage" />
        </Tab>
        <!--<Tab Title="Comms" Icon="comms.png">
            <ShellContent
            ContentTemplate="{DataTemplate pages:Comms}"
            Route="Comms" />
        </Tab>-->
    </TabBar>
    


</Shell>
